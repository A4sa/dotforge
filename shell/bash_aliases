alias lsserial='echo "=== by-id (stable) ===" && \
    ls /dev/serial/by-id/ 2>/dev/null || echo "none" && \
    echo "=== raw devices ===" && \
    ls /dev/ttyUSB* /dev/ttyACM* 2>/dev/null || echo "none"'

# =====================  KERNEL / BSP HELPERS ===========================
alias kconfig='make menuconfig'            # Open Kernel config menu

# Search for Kernal config by name ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ> kgrep USB_SERIAL
kgrep() {
    if [ -z "$1" ]; then
        echo "Usage: kgrep <CONFIG_OPTION>"
        echo "  e.g. kgrep USB_SERIAL"
        return 1
    fi
    grep -i "$1" .config 2>/dev/null || echo "No .config found in current directory"
}

# Ceck if Kernel module is loaded ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ> modcheck i2c_dev
modcheck() {
    lsmod | grep -i "$1" || echo "Module '$1' is not loaded"
}

# demsg output for specific  ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ> dlog i2c 
dlog() {
    sudo dmesg  | grep -i "$1"
}

