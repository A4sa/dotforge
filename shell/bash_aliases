# ================== ANDROID DEBUG BRIDGE (ADB) ======================
alias shell='adb shell' 
alias adbdev='adb devices'               # List connected devices
alias adblog='adb logcat'                # Stream Android logcat output
alias adbr='adb reboot'                  # Reboot the target device

# USAGE: adbpush ./my_binary /data/local/tmp/
adbpush() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: adbpush <local_file> <remote_path>"
        return 1
    fi
    adb push "$1" "$2" && adb shell chmod +x "$2/$( basename $1 )"
    echo "Pushed and chmod +x: $2/$(basename $1)"
}

