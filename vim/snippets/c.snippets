#
#  File name   : c.snippets
#  Author      : Abdul Sattar <abdul.linuxdev@gmail.com>
#  Repository  : https://github.com/A4sa/dotforge.git
#  Description : UltiSnips snippets for embedded C and Linux kernel development.
#
#  HOW ULTISNIPS WORKS
#  -------------------
#  1. Type the trigger word in INSERT mode
#  2. Press Tab  вҶ’ expands the snippet
#  3. Press Tab  вҶ’ jump to next placeholder  ($1, $2 ...)
#  4. Press S-Tab вҶ’ jump to previous placeholder
#  5. ${1:default} вҶ’ placeholder with a default value
#  6. $0          вҶ’ final cursor position after all tabs
#
#  INSTALL ULTISNIPS
#  -----------------
#  Add to plugin_config.vim:
#    Plug 'SirVer/ultisnips'
#    Plug 'honza/vim-snippets'    " optional community snippets
#
#  Add to plugin_config.vim config section:
#    let g:UltiSnipsExpandTrigger       = '<tab>'
#    let g:UltiSnipsJumpForwardTrigger  = '<tab>'
#    let g:UltiSnipsJumpBackwardTrigger = '<s-tab>'
#    let g:UltiSnipsEditSplit           = 'vertical'
#
#  PLACE THIS FILE AT:
#    ~/.vim/UltiSnips/c.snippets
#    OR: vim/snippets/c.snippets  (symlinked by install.sh)
#
#  TABLE OF CONTENTS
#  -----------------
#  [1]  File Header
#  [2]  Header Guards
#  [3]  Kernel Module Skeleton
#  [4]  Platform Driver
#  [5]  I2C Driver
#  [6]  SPI Driver
#  [7]  Interrupt Handler
#  [8]  Device Tree Binding Stub
#  [9]  Debug & Logging
#  [10] Common Kernel Patterns
#  [11] Memory Management
#  [12] Miscellaneous C Patterns
#
# ============================================================================


# ============================================================================
# [1]  FILE HEADER
# ============================================================================

# trigger: fhdr
# Inserts a professional file header comment block
snippet fhdr "File header for kernel/BSP source files" b
// SPDX-License-Identifier: GPL-2.0-only
/*
 * ${1:driver_name}.c вҖ” ${2:Brief description of what this driver does}
 *
 * Author  : ${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>
 * Created : `!v strftime('%B %Y')`
 *
 * ${5:Longer description: what hardware this drives, which SoC/board,
 * key design decisions, register map reference, etc.}
 */

#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/init.h>
$0
endsnippet


# ============================================================================
# [2]  HEADER GUARDS
# ============================================================================

# trigger: hguard
# Standard #ifndef header guard вҖ” uses the filename automatically
snippet hguard "Header file guard (#ifndef)" b
#ifndef ${1:`!v toupper(substitute(expand('%:t:r'), '[^a-zA-Z0-9]', '_', 'g'))`}_H
#define ${1:`!v toupper(substitute(expand('%:t:r'), '[^a-zA-Z0-9]', '_', 'g'))`}_H

#ifdef __cplusplus
extern "C" {
#endif

$0

#ifdef __cplusplus
}
#endif

#endif /* ${1:`!v toupper(substitute(expand('%:t:r'), '[^a-zA-Z0-9]', '_', 'g'))`}_H */
endsnippet

# trigger: once
# Pragma once (non-standard but widely supported)
snippet once "Pragma once header guard" b
#pragma once

$0
endsnippet


# ============================================================================
# [3]  KERNEL MODULE SKELETON
# ============================================================================

# trigger: kmod
# Full minimal kernel module вҖ” compiles and loads out of the box
snippet kmod "Minimal kernel module skeleton" b
// SPDX-License-Identifier: GPL-2.0-only
/*
 * ${1:module_name}.c вҖ” ${2:Module description}
 *
 * Author: ${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>
 */

#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/init.h>

#define DRIVER_NAME "${1:module_name}"

static int __init ${1:module_name}_init(void)
{
	pr_info(DRIVER_NAME ": loaded\n");
	return 0;
}

static void __exit ${1:module_name}_exit(void)
{
	pr_info(DRIVER_NAME ": unloaded\n");
}

module_init(${1:module_name}_init);
module_exit(${1:module_name}_exit);

MODULE_AUTHOR("${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>");
MODULE_DESCRIPTION("${2:Module description}");
MODULE_LICENSE("GPL v2");
$0
endsnippet

# trigger: kmod_make
# Minimal out-of-tree Makefile for a kernel module
snippet kmod_make "Out-of-tree kernel module Makefile" b
# Minimal out-of-tree Makefile
# Usage:
#   make -C /lib/modules/$(uname -r)/build M=$(pwd) modules
#   make -C /lib/modules/$(uname -r)/build M=$(pwd) clean

obj-m += ${1:module_name}.o

# If your module has multiple source files:
# ${1:module_name}-objs := file1.o file2.o

KDIR ?= /lib/modules/$(shell uname -r)/build

all:
	$(MAKE) -C $(KDIR) M=$(PWD) modules

clean:
	$(MAKE) -C $(KDIR) M=$(PWD) clean
$0
endsnippet


# ============================================================================
# [4]  PLATFORM DRIVER
# ============================================================================

# trigger: platdrv
# Full platform_driver skeleton with probe/remove/of_match_table
snippet platdrv "Linux platform driver skeleton" b
// SPDX-License-Identifier: GPL-2.0-only
/*
 * ${1:driver_name}.c вҖ” ${2:Platform driver for X peripheral}
 *
 * Author: ${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>
 */

#include <linux/module.h>
#include <linux/platform_device.h>
#include <linux/of.h>
#include <linux/of_device.h>
#include <linux/io.h>
#include <linux/clk.h>

#define DRIVER_NAME "${1:driver_name}"

/* Private data structure вҖ” one instance per device */
struct ${1:driver_name}_priv {
	struct device	*dev;
	void __iomem	*base;		/* MMIO base address */
	struct clk	*clk;		/* peripheral clock */
	int		 irq;		/* interrupt line */
};

static int ${1:driver_name}_probe(struct platform_device *pdev)
{
	struct ${1:driver_name}_priv *priv;
	struct resource *res;
	int ret;

	priv = devm_kzalloc(&pdev->dev, sizeof(*priv), GFP_KERNEL);
	if (!priv)
		return -ENOMEM;

	priv->dev = &pdev->dev;

	/* Map MMIO registers */
	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
	priv->base = devm_ioremap_resource(&pdev->dev, res);
	if (IS_ERR(priv->base))
		return PTR_ERR(priv->base);

	/* Get and enable clock */
	priv->clk = devm_clk_get(&pdev->dev, NULL);
	if (IS_ERR(priv->clk)) {
		dev_err(&pdev->dev, "failed to get clock\n");
		return PTR_ERR(priv->clk);
	}

	ret = clk_prepare_enable(priv->clk);
	if (ret) {
		dev_err(&pdev->dev, "failed to enable clock: %d\n", ret);
		return ret;
	}

	/* Get IRQ */
	priv->irq = platform_get_irq(pdev, 0);
	if (priv->irq < 0)
		return priv->irq;

	platform_set_drvdata(pdev, priv);

	dev_info(&pdev->dev, "${1:driver_name} probed successfully\n");
	return 0;
}

static int ${1:driver_name}_remove(struct platform_device *pdev)
{
	struct ${1:driver_name}_priv *priv = platform_get_drvdata(pdev);

	clk_disable_unprepare(priv->clk);

	dev_info(&pdev->dev, "${1:driver_name} removed\n");
	return 0;
}

/* Device Tree match table */
static const struct of_device_id ${1:driver_name}_of_match[] = {
	{ .compatible = "${5:vendor,driver-name}" },
	{ /* sentinel */ }
};
MODULE_DEVICE_TABLE(of, ${1:driver_name}_of_match);

static struct platform_driver ${1:driver_name}_driver = {
	.probe  = ${1:driver_name}_probe,
	.remove = ${1:driver_name}_remove,
	.driver = {
		.name           = DRIVER_NAME,
		.of_match_table = ${1:driver_name}_of_match,
	},
};

module_platform_driver(${1:driver_name}_driver);

MODULE_AUTHOR("${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>");
MODULE_DESCRIPTION("${2:Platform driver for X peripheral}");
MODULE_LICENSE("GPL v2");
$0
endsnippet


# ============================================================================
# [5]  I2C DRIVER
# ============================================================================

# trigger: i2cdrv
# Full i2c_driver skeleton with probe/remove/id_table/of_match
snippet i2cdrv "Linux I2C driver skeleton" b
// SPDX-License-Identifier: GPL-2.0-only
/*
 * ${1:driver_name}.c вҖ” ${2:I2C driver for X sensor/device}
 *
 * Author: ${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>
 */

#include <linux/module.h>
#include <linux/i2c.h>
#include <linux/of.h>
#include <linux/regmap.h>

#define DRIVER_NAME "${1:driver_name}"

/* Register map */
#define ${5:REG_STATUS}		0x00
#define ${6:REG_CTRL}		0x01

struct ${1:driver_name}_priv {
	struct i2c_client	*client;
	struct regmap		*regmap;
};

static const struct regmap_config ${1:driver_name}_regmap_config = {
	.reg_bits  = 8,
	.val_bits  = 8,
	.max_register = 0xFF,
};

static int ${1:driver_name}_probe(struct i2c_client *client,
				  const struct i2c_device_id *id)
{
	struct ${1:driver_name}_priv *priv;

	priv = devm_kzalloc(&client->dev, sizeof(*priv), GFP_KERNEL);
	if (!priv)
		return -ENOMEM;

	priv->client = client;

	priv->regmap = devm_regmap_init_i2c(client, &${1:driver_name}_regmap_config);
	if (IS_ERR(priv->regmap)) {
		dev_err(&client->dev, "failed to init regmap\n");
		return PTR_ERR(priv->regmap);
	}

	i2c_set_clientdata(client, priv);

	dev_info(&client->dev, "${1:driver_name} probed at 0x%02x\n",
		 client->addr);
	return 0;
}

static int ${1:driver_name}_remove(struct i2c_client *client)
{
	dev_info(&client->dev, "${1:driver_name} removed\n");
	return 0;
}

static const struct i2c_device_id ${1:driver_name}_id[] = {
	{ "${1:driver_name}", 0 },
	{ }
};
MODULE_DEVICE_TABLE(i2c, ${1:driver_name}_id);

static const struct of_device_id ${1:driver_name}_of_match[] = {
	{ .compatible = "${7:vendor,driver-name}" },
	{ }
};
MODULE_DEVICE_TABLE(of, ${1:driver_name}_of_match);

static struct i2c_driver ${1:driver_name}_driver = {
	.driver = {
		.name           = DRIVER_NAME,
		.of_match_table = ${1:driver_name}_of_match,
	},
	.probe    = ${1:driver_name}_probe,
	.remove   = ${1:driver_name}_remove,
	.id_table = ${1:driver_name}_id,
};

module_i2c_driver(${1:driver_name}_driver);

MODULE_AUTHOR("${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>");
MODULE_DESCRIPTION("${2:I2C driver for X sensor/device}");
MODULE_LICENSE("GPL v2");
$0
endsnippet


# ============================================================================
# [6]  SPI DRIVER
# ============================================================================

# trigger: spidrv
# Full spi_driver skeleton
snippet spidrv "Linux SPI driver skeleton" b
// SPDX-License-Identifier: GPL-2.0-only
/*
 * ${1:driver_name}.c вҖ” ${2:SPI driver for X device}
 *
 * Author: ${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>
 */

#include <linux/module.h>
#include <linux/spi/spi.h>
#include <linux/of.h>

#define DRIVER_NAME "${1:driver_name}"

struct ${1:driver_name}_priv {
	struct spi_device *spi;
};

static int ${1:driver_name}_probe(struct spi_device *spi)
{
	struct ${1:driver_name}_priv *priv;
	int ret;

	priv = devm_kzalloc(&spi->dev, sizeof(*priv), GFP_KERNEL);
	if (!priv)
		return -ENOMEM;

	priv->spi = spi;

	/* Configure SPI mode */
	spi->mode = SPI_MODE_${5:0};
	spi->bits_per_word = ${6:8};
	ret = spi_setup(spi);
	if (ret) {
		dev_err(&spi->dev, "spi_setup failed: %d\n", ret);
		return ret;
	}

	spi_set_drvdata(spi, priv);

	dev_info(&spi->dev, "${1:driver_name} probed\n");
	return 0;
}

static int ${1:driver_name}_remove(struct spi_device *spi)
{
	dev_info(&spi->dev, "${1:driver_name} removed\n");
	return 0;
}

static const struct of_device_id ${1:driver_name}_of_match[] = {
	{ .compatible = "${7:vendor,driver-name}" },
	{ }
};
MODULE_DEVICE_TABLE(of, ${1:driver_name}_of_match);

static const struct spi_device_id ${1:driver_name}_id[] = {
	{ "${1:driver_name}", 0 },
	{ }
};
MODULE_DEVICE_TABLE(spi, ${1:driver_name}_id);

static struct spi_driver ${1:driver_name}_driver = {
	.driver = {
		.name           = DRIVER_NAME,
		.of_match_table = ${1:driver_name}_of_match,
	},
	.probe    = ${1:driver_name}_probe,
	.remove   = ${1:driver_name}_remove,
	.id_table = ${1:driver_name}_id,
};

module_spi_driver(${1:driver_name}_driver);

MODULE_AUTHOR("${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>");
MODULE_DESCRIPTION("${2:SPI driver for X device}");
MODULE_LICENSE("GPL v2");
$0
endsnippet


# ============================================================================
# [7]  INTERRUPT HANDLER
# ============================================================================

# trigger: irqh
# Request an IRQ with a handler вҖ” devm_ version (auto-freed on remove)
snippet irqh "IRQ request + handler skeleton" b
/* IRQ handler */
static irqreturn_t ${1:driver_name}_irq_handler(int irq, void *dev_id)
{
	struct ${1:driver_name}_priv *priv = dev_id;

	/* TODO: read status register to confirm this IRQ is ours */
	/* TODO: clear the interrupt at the hardware level */
	/* TODO: wake any waiting threads / schedule bottom half */

	return IRQ_HANDLED;
}

/* In probe(): request the IRQ */
ret = devm_request_irq(&pdev->dev, priv->irq,
		       ${1:driver_name}_irq_handler,
		       IRQF_${2:TRIGGER_RISING},
		       DRIVER_NAME, priv);
if (ret) {
	dev_err(&pdev->dev, "failed to request IRQ %d: %d\n",
		priv->irq, ret);
	return ret;
}
$0
endsnippet

# trigger: irqth
# Threaded IRQ handler (top half + bottom half)
snippet irqth "Threaded IRQ handler (hard IRQ + thread)" b
/* Hard IRQ вҖ” runs in interrupt context, must be fast */
static irqreturn_t ${1:driver_name}_hard_irq(int irq, void *dev_id)
{
	/* Acknowledge hardware interrupt, return IRQ_WAKE_THREAD */
	return IRQ_WAKE_THREAD;
}

/* Threaded handler вҖ” runs in kernel thread context, can sleep */
static irqreturn_t ${1:driver_name}_thread_irq(int irq, void *dev_id)
{
	struct ${1:driver_name}_priv *priv = dev_id;

	/* Safe to sleep here вҖ” read registers, process data */
	$0

	return IRQ_HANDLED;
}

/* In probe(): */
ret = devm_request_threaded_irq(&pdev->dev, priv->irq,
				${1:driver_name}_hard_irq,
				${1:driver_name}_thread_irq,
				IRQF_${2:TRIGGER_RISING},
				DRIVER_NAME, priv);
endsnippet


# ============================================================================
# [8]  DEVICE TREE BINDING
# ============================================================================

# trigger: dtnode
# DTS node for a platform device (paste into your .dts file)
snippet dtnode "DTS device node for a platform device" b
/* ${1:Peripheral name} вҖ” ${2:brief description} */
${3:node_name}: ${3:node_name}@${4:base_address} {
	compatible = "${5:vendor,driver-name}";
	reg = <0x0 0x${4:base_address} 0x0 0x${6:size}>;
	interrupts = <${7:GIC_SPI} ${8:irq_number} ${9:IRQ_TYPE_LEVEL_HIGH}>;
	interrupt-parent = <&${10:gic}>;
	clocks = <&${11:clk_controller} ${12:CLK_PERIPH}>;
	clock-names = "${13:apb_clk}";
	status = "${14:okay}";
	$0
};
endsnippet

# trigger: dti2c
# DTS node for an I2C slave device
snippet dti2c "DTS I2C slave device node" b
/* ${1:Device name} on I2C bus */
&${2:i2c0} {
	${3:device_name}: ${3:device_name}@${4:address} {
		compatible = "${5:vendor,device-name}";
		reg = <0x${4:address}>;
		${6:#interrupt-cells = <1>;}
		${7:interrupt-parent = <&gpio>;}
		${8:interrupts = <pin IRQ_TYPE_EDGE_FALLING>;}
		status = "okay";
		$0
	};
};
endsnippet

# trigger: dtspi
# DTS node for an SPI slave device
snippet dtspi "DTS SPI slave device node" b
/* ${1:Device name} on SPI bus */
&${2:spi0} {
	${3:device_name}: ${3:device_name}@${4:0} {
		compatible = "${5:vendor,device-name}";
		reg = <${4:0}>;
		spi-max-frequency = <${6:1000000}>;
		${7:spi-cpol;}
		${8:spi-cpha;}
		status = "okay";
		$0
	};
};
endsnippet


# ============================================================================
# [9]  DEBUG & LOGGING
# ============================================================================

# trigger: pri
# pr_info вҖ” general kernel log (no device context)
snippet pri "pr_info log message" b
pr_info("${1:DRIVER}: ${2:message}\n"${3:, args});
$0
endsnippet

# trigger: pre
# pr_err вҖ” kernel error log
snippet pre "pr_err error message" b
pr_err("${1:DRIVER}: ${2:error message}: %d\n", ${3:ret});
$0
endsnippet

# trigger: devi
# dev_info вҖ” log with device context (preferred in drivers)
snippet devi "dev_info with device context" b
dev_info(${1:dev}, "${2:message}\n"${3:, args});
$0
endsnippet

# trigger: deve
# dev_err вҖ” device-context error log
snippet deve "dev_err with device context" b
dev_err(${1:dev}, "${2:error message}: %d\n", ${3:ret});
$0
endsnippet

# trigger: devd
# dev_dbg вҖ” debug message (only prints when DEBUG is defined or dynamic debug enabled)
snippet devd "dev_dbg debug message (dynamic debug)" b
dev_dbg(${1:dev}, "${2:debug message}\n"${3:, args});
$0
endsnippet

# trigger: devw
# dev_warn вҖ” device warning
snippet devw "dev_warn warning message" b
dev_warn(${1:dev}, "${2:warning message}\n"${3:, args});
$0
endsnippet

# trigger: dbg
# pr_debug block вҖ” prints only when module is compiled with DEBUG or
# dynamic debug is enabled for this file. Zero cost in production.
snippet dbg "pr_debug with file/line context" b
pr_debug("%s:%d вҖ” ${1:message}\n", __func__, __LINE__${2:, args});
$0
endsnippet

# trigger: WARN
# WARN_ON вҖ” prints stack trace if condition is true (debug assertion)
snippet WARN "WARN_ON assertion with message" b
if (WARN_ON(${1:condition})) {
	dev_err(${2:dev}, "${3:unexpected condition reached}\n");
	return ${4:-EINVAL};
}
$0
endsnippet


# ============================================================================
# [10]  COMMON KERNEL PATTERNS
# ============================================================================

# trigger: devm
# devm_kzalloc вҖ” the standard way to allocate private driver data
snippet devm "devm_kzalloc private data allocation" b
${1:priv} = devm_kzalloc(${2:dev}, sizeof(*${1:priv}), GFP_KERNEL);
if (!${1:priv})
	return -ENOMEM;
$0
endsnippet

# trigger: ofprop
# of_property_read вҖ” read a DT property into a variable
snippet ofprop "of_property_read_u32 from device tree" b
ret = of_property_read_u32(${1:np}, "${2:property-name}", &${3:value});
if (ret) {
	dev_err(${4:dev}, "missing required DT property '${2:property-name}'\n");
	return ret;
}
$0
endsnippet

# trigger: mutex
# mutex_lock / unlock pair with proper error handling
snippet mutex "mutex_lock/unlock pair" b
mutex_lock(&${1:priv}->${2:lock});

${3:/* critical section */}

mutex_unlock(&${1:priv}->${2:lock});
$0
endsnippet

# trigger: spinl
# spin_lock_irqsave / spin_unlock_irqrestore
snippet spinl "spin_lock_irqsave / spin_unlock_irqrestore" b
unsigned long flags;

spin_lock_irqsave(&${1:priv}->${2:lock}, flags);

${3:/* critical section вҖ” cannot sleep here */}

spin_unlock_irqrestore(&${1:priv}->${2:lock}, flags);
$0
endsnippet

# trigger: regr
# regmap_read вҖ” read a hardware register via regmap
snippet regr "regmap_read register" b
ret = regmap_read(${1:priv}->regmap, ${2:REG_NAME}, &${3:val});
if (ret) {
	dev_err(${1:priv}->dev, "failed to read ${2:REG_NAME}: %d\n", ret);
	return ret;
}
$0
endsnippet

# trigger: regw
# regmap_write вҖ” write a hardware register via regmap
snippet regw "regmap_write register" b
ret = regmap_write(${1:priv}->regmap, ${2:REG_NAME}, ${3:val});
if (ret) {
	dev_err(${1:priv}->dev, "failed to write ${2:REG_NAME}: %d\n", ret);
	return ret;
}
$0
endsnippet

# trigger: regupd
# regmap_update_bits вҖ” set/clear specific bits in a register
snippet regupd "regmap_update_bits вҖ” modify specific register bits" b
ret = regmap_update_bits(${1:priv}->regmap, ${2:REG_NAME},
			 ${3:MASK}, ${4:value});
if (ret) {
	dev_err(${1:priv}->dev, "failed to update ${2:REG_NAME}: %d\n", ret);
	return ret;
}
$0
endsnippet

# trigger: waitq
# wait_event_interruptible вҖ” block until condition is true
snippet waitq "wait_event_interruptible wait queue" b
/* Declaration (in priv struct): wait_queue_head_t ${1:wq}; */
/* Initialization (in probe):    init_waitqueue_head(&priv->${1:wq}); */
/* Wake up (in IRQ handler):     wake_up_interruptible(&priv->${1:wq}); */

ret = wait_event_interruptible(${2:priv}->${1:wq}, ${3:condition});
if (ret)
	return -ERESTARTSYS;
$0
endsnippet


# ============================================================================
# [11]  MEMORY MANAGEMENT
# ============================================================================

# trigger: iomap
# ioremap вҖ” map physical MMIO address to virtual address
snippet iomap "ioremap MMIO region" b
${1:priv}->base = devm_ioremap(${2:dev}, ${3:phys_addr}, ${4:size});
if (!${1:priv}->base) {
	dev_err(${2:dev}, "failed to ioremap 0x%llx\n",
		(unsigned long long)${3:phys_addr});
	return -ENOMEM;
}
$0
endsnippet

# trigger: dma
# DMA coherent allocation
snippet dma "dma_alloc_coherent buffer" b
${1:priv}->${2:buf} = dma_alloc_coherent(${3:dev}, ${4:size},
				   &${1:priv}->${2:buf}_dma, GFP_KERNEL);
if (!${1:priv}->${2:buf}) {
	dev_err(${3:dev}, "failed to allocate DMA buffer\n");
	return -ENOMEM;
}
/* Free with: dma_free_coherent(dev, size, priv->buf, priv->buf_dma); */
$0
endsnippet


# ============================================================================
# [12]  MISCELLANEOUS C PATTERNS
# ============================================================================

# trigger: ifnull
# NULL check with error return
snippet ifnull "NULL pointer check" b
if (!${1:ptr}) {
	pr_err("${2:error}: null pointer\n");
	return ${3:-EINVAL};
}
$0
endsnippet

# trigger: retcheck
# Return value check pattern вҖ” used constantly in kernel code
snippet retcheck "Return value error check" b
ret = ${1:function}(${2:args});
if (ret) {
	dev_err(${3:dev}, "${1:function} failed: %d\n", ret);
	return ret;
}
$0
endsnippet

# trigger: bfield
# Bit field operations using BIT(), GENMASK(), FIELD_GET()
snippet bfield "Bit field macros вҖ” BIT, GENMASK, FIELD_GET/PREP" b
/* Single bit */
#define ${1:REG}_${2:FLAG}_BIT		BIT(${3:0})

/* Multi-bit field */
#define ${1:REG}_${4:FIELD}_MASK	GENMASK(${5:7}, ${6:4})
#define ${1:REG}_${4:FIELD}(x)		FIELD_PREP(${1:REG}_${4:FIELD}_MASK, (x))

/* Extract field value from register */
/* u32 val = FIELD_GET(REG_FIELD_MASK, reg_value); */
$0
endsnippet

# trigger: foreach
# list_for_each_entry вҖ” iterate a kernel linked list
snippet foreach "list_for_each_entry kernel list iteration" b
list_for_each_entry(${1:entry}, &${2:head}, ${3:list_member}) {
	$0
}
endsnippet

# trigger: cdev
# character device registration skeleton
snippet cdev "Character device (cdev) registration" b
#include <linux/cdev.h>
#include <linux/fs.h>

static dev_t ${1:drv}_devno;
static struct cdev ${1:drv}_cdev;
static struct class *${1:drv}_class;

static const struct file_operations ${1:drv}_fops = {
	.owner   = THIS_MODULE,
	.open    = ${1:drv}_open,
	.release = ${1:drv}_release,
	.read    = ${1:drv}_read,
	.write   = ${1:drv}_write,
	.unlocked_ioctl = ${1:drv}_ioctl,
};

/* In init/probe: */
ret = alloc_chrdev_region(&${1:drv}_devno, 0, 1, "${1:drv}");
cdev_init(&${1:drv}_cdev, &${1:drv}_fops);
ret = cdev_add(&${1:drv}_cdev, ${1:drv}_devno, 1);
${1:drv}_class = class_create(THIS_MODULE, "${1:drv}");
device_create(${1:drv}_class, NULL, ${1:drv}_devno, NULL, "${1:drv}");

/* In exit/remove: */
device_destroy(${1:drv}_class, ${1:drv}_devno);
class_destroy(${1:drv}_class);
cdev_del(&${1:drv}_cdev);
unregister_chrdev_region(${1:drv}_devno, 1);
$0
endsnippet
