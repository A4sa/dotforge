# trigger: main
# Full argparse-based script entry point ‚ÄĒ the standard structure for
# any command-line tool used in embedded automation
snippet main "argparse CLI script entry point" b
import argparse
import sys
import logging

log = logging.getLogger(__name__)


def parse_args():
    parser = argparse.ArgumentParser(
        description="${1:Script description}",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
    %(prog)s --${2:option} ${3:value}
    %(prog)s --verbose --${2:option} ${3:value}
        """,
    )
    parser.add_argument(
        "--${2:option}",
        type=${4:str},
        required=${5:True},
        help="${6:Description of this option}",
    )
    parser.add_argument(
        "--verbose", "-v",
        action="store_true",
        help="Enable verbose debug output",
    )
    return parser.parse_args()


def main(args):
    $0
    return 0


if __name__ == "__main__":
    args = parse_args()
    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%H:%M:%S",
    )
    sys.exit(main(args))
endsnippet

