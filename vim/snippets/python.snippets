# trigger: retry
# Retry decorator ‚ÄĒ useful for flaky hardware operations
snippet retry "Retry decorator for flaky operations" b
import time
import functools

def retry(attempts: int = 3, delay: float = 1.0, exceptions=(Exception,)):
    """
    Decorator to retry a function on failure.
    Useful for flaky serial/SSH operations on embedded targets.

    Usage:
        @retry(attempts=3, delay=0.5, exceptions=(TimeoutError,))
        def read_sensor():
            ...
    """
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            last_exc = None
            for attempt in range(1, attempts + 1):
                try:
                    return func(*args, **kwargs)
                except exceptions as e:
                    last_exc = e
                    log.warning("Attempt %d/%d failed: %s", attempt, attempts, e)
                    if attempt < attempts:
                        time.sleep(delay)
            raise last_exc
        return wrapper
    return decorator
$0
endsnippet

# trigger: timer
# Simple elapsed time measurement context manager
snippet timer "Elapsed time measurement" b
import time
from contextlib import contextmanager

@contextmanager
def timer(label: str = "elapsed"):
    """Measure and print the time a block of code takes to run."""
    start = time.monotonic()
    try:
        yield
    finally:
        elapsed = time.monotonic() - start
        print(f"{label}: {elapsed:.3f}s")

# Usage:
# with timer("kernel build"):
#     run_cmd(["make", "-j8"])
$0
endsnippet

