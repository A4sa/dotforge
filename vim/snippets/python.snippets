snippet fhdr "Python script file header" b
#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
${1:script_name}.py ‚ÄĒ ${2:Brief description of what this script does}

Author  : ${3:Abdul Sattar} <${4:abdul.linuxdev@gmail.com}>
Created : `!v strftime('%B %Y')`
Repo    : https://github.com/A4sa/dotforge

Usage:
    python3 ${1:script_name}.py ${5:[options]}

Description:
    ${6:Longer description of the script's purpose, inputs, and outputs.}
"""

$0
endsnippet


