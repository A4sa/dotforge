# trigger: readfile
# Safe file reader with error handling
snippet readfile "Read file with error handling" b
from pathlib import Path

def read_file(path: str) -> str:
    """Read a file and return its contents. Returns empty string on error."""
    try:
        return Path(path).read_text(encoding="utf-8")
    except FileNotFoundError:
        log.error("File not found: %s", path)
        return ""
    except PermissionError:
        log.error("Permission denied: %s", path)
        return ""
$0
endsnippet


# ============================================================================
# [8]  REGISTER / BITFIELD TOOLS
# ============================================================================
#
# WHY: Parsing hex register dumps, computing bitmasks, and formatting
#      register values are daily tasks in BSP and driver debugging.

# trigger: regparse
# Parse and display a hardware register value with named bitfields
snippet regparse "Register bitfield parser and display" b
class Register:
    """
    Parse and display a hardware register with named bitfields.

    Usage:
        reg = Register("CTRL", 0x${1:1A}, fields={
            "ENABLE":   (${2:0},  ${3:0}),   # bit 0
            "MODE":     (${4:2},  ${5:1}),   # bits 2:1
            "CLK_DIV":  (${6:7},  ${7:3}),   # bits 7:3
        })
        reg.dump()
    """

    def __init__(self, name: str, value: int, fields: dict):
        self.name  = name
        self.value = value
        self.fields = fields  # {field_name: (msb, lsb)}

    def get(self, field: str) -> int:
        msb, lsb = self.fields[field]
        mask = (1 << (msb - lsb + 1)) - 1
        return (self.value >> lsb) & mask

    def dump(self):
        print(f"Register: {self.name} = 0x{self.value:08X} ({self.value:#034b})")
        print(f"  {'Field':<16} {'Bits':>8}  {'Value':>10}  {'Hex':>8}")
        print(f"  {'-'*16} {'-'*8}  {'-'*10}  {'-'*8}")
        for name, (msb, lsb) in sorted(self.fields.items(),
                                        key=lambda x: x[1][1], reverse=True):
            val = self.get(name)
            bits = f"[{msb}:{lsb}]" if msb != lsb else f"[{msb}]"
            print(f"  {name:<16} {bits:>8}  {val:>10}  {val:#010x}")
$0
endsnippet

# trigger: bitmask
# Compute a bitmask for a register field
snippet bitmask "Bitmask and field extraction helpers" b
def bitmask(msb: int, lsb: int) -> int:
    """Return a bitmask for bits [msb:lsb]."""
    return ((1 << (msb - lsb + 1)) - 1) << lsb

def get_field(reg: int, msb: int, lsb: int) -> int:
    """Extract a bitfield from a register value."""
    return (reg >> lsb) & ((1 << (msb - lsb + 1)) - 1)

def set_field(reg: int, msb: int, lsb: int, val: int) -> int:
    """Set a bitfield in a register value."""
    mask = bitmask(msb, lsb)
    return (reg & ~mask) | ((val << lsb) & mask)

# Usage:
# ctrl = 0x1A
# mode = get_field(ctrl, 2, 1)       # extract bits [2:1]
# ctrl = set_field(ctrl, 2, 1, 0x3)  # set bits [2:1] = 3
$0
endsnippet


