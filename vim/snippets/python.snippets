# trigger: sub
# subprocess.run ‚ÄĒ the modern way to run shell commands from Python
snippet sub "subprocess.run shell command" b
import subprocess

def run_cmd(cmd: list[str], check: bool = True,
            capture: bool = True) -> subprocess.CompletedProcess:
    """
    Run a shell command.
    Args:
        cmd    ‚ÄĒ command as a list: ['make', '-j4']
        check  ‚ÄĒ raise CalledProcessError on non-zero exit
        capture ‚ÄĒ capture stdout/stderr (False = print to terminal)
    """
    return subprocess.run(
        cmd,
        check=check,
        capture_output=capture,
        text=True,
    )


# Usage:
# result = run_cmd(['make', '-j4'])
# print(result.stdout)
$0
endsnippet

# trigger: shell
# Quick one-liner subprocess call ‚ÄĒ run and return output
snippet shell "subprocess one-liner ‚ÄĒ run and return stdout" b
import subprocess
def shell(cmd: str) -> str:
    """Run a shell command string and return stdout. Raises on error."""
    return subprocess.check_output(cmd, shell=True, text=True).strip()

# Usage: kernel_ver = shell("uname -r")
$0
endsnippet


