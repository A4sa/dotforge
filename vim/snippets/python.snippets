# ============================================================================
# [4]  SERIAL COMMUNICATION
# ============================================================================
#
# WHY: Serial is the primary debug interface in embedded Linux.
#      pyserial is the standard Python library for UART communication.
# INSTALL: pip3 install pyserial

# trigger: serial
# Full serial port communication class
snippet serial "pyserial serial port communication" b
import serial
import serial.tools.list_ports
import time
import logging

log = logging.getLogger(__name__)


class SerialComm:
    """UART serial communication wrapper for embedded device console."""

    def __init__(self, port: str, baud: int = 115200,
                 timeout: float = 1.0, flow: bool = False):
        self.port = port
        self.baud = baud
        self._ser = None

        self._ser = serial.Serial(
            port=port,
            baudrate=baud,
            bytesize=serial.EIGHTBITS,
            parity=serial.PARITY_NONE,
            stopbits=serial.STOPBITS_ONE,
            rtscts=flow,   # hardware flow control ‚ÄĒ False for most targets
            timeout=timeout,
        )
        log.info("Connected: %s @ %d baud", port, baud)

    def send(self, cmd: str, end: str = "\n") -> None:
        """Send a command string to the target."""
        data = (cmd + end).encode("utf-8")
        self._ser.write(data)
        log.debug("TX: %r", cmd)

    def read_until(self, prompt: str, timeout: float = 10.0) -> str:
        """Read lines until the expected prompt string appears."""
        output = []
        deadline = time.monotonic() + timeout
        while time.monotonic() < deadline:
            line = self._ser.readline().decode("utf-8", errors="replace")
            if line:
                output.append(line.rstrip())
                log.debug("RX: %s", line.rstrip())
                if prompt in line:
                    break
        return "\n".join(output)

    def expect_login(self, user: str = "root", password: str = "") -> bool:
        """Wait for login prompt and authenticate."""
        self.read_until("login:", timeout=30)
        self.send(user)
        if password:
            self.read_until("Password:")
            self.send(password)
        resp = self.read_until("# ", timeout=10)
        return "# " in resp

    def close(self) -> None:
        if self._ser and self._ser.is_open:
            self._ser.close()

    def __enter__(self):
        return self

    def __exit__(self, *_):
        self.close()


def list_serial_ports():
    """List all available serial ports."""
    ports = serial.tools.list_ports.comports()
    for p in ports:
        print(f"  {p.device:15} ‚ÄĒ {p.description}")


if __name__ == "__main__":
    list_serial_ports()
    with SerialComm("${1:/dev/ttyUSB0}", baud=${2:115200}) as s:
        s.send("${3:uname -r}")
        print(s.read_until("${4:# }"))
$0
endsnippet


# ============================================================================
# [5]  SSH / REMOTE COMMAND EXECUTION
# ============================================================================
#
# WHY: Automated board testing ‚ÄĒ SSH into a target, run commands, capture output.
# INSTALL: pip3 install paramiko

# trigger: ssh
# SSH connection class using paramiko
snippet ssh "paramiko SSH remote command execution" b
import paramiko
import logging

log = logging.getLogger(__name__)


class SSHClient:
    """SSH wrapper for remote command execution on embedded targets."""

    def __init__(self, host: str, user: str = "root",
                 password: str = "", port: int = 22, timeout: int = 10):
        self._client = paramiko.SSHClient()
        self._client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        self._client.connect(
            hostname=host,
            username=user,
            password=password,
            port=port,
            timeout=timeout,
        )
        log.info("SSH connected: %s@%s:%d", user, host, port)

    def run(self, cmd: str, timeout: int = 30) -> tuple[int, str, str]:
        """
        Run a command on the remote host.
        Returns: (exit_code, stdout, stderr)
        """
        log.debug("SSH run: %s", cmd)
        _, stdout, stderr = self._client.exec_command(cmd, timeout=timeout)
        exit_code = stdout.channel.recv_exit_status()
        out = stdout.read().decode().strip()
        err = stderr.read().decode().strip()
        if exit_code != 0:
            log.warning("Command failed (rc=%d): %s\nstderr: %s",
                        exit_code, cmd, err)
        return exit_code, out, err

    def run_check(self, cmd: str) -> str:
        """Run a command and raise RuntimeError on failure."""
        rc, out, err = self.run(cmd)
        if rc != 0:
            raise RuntimeError(f"Command failed: {cmd!r}\n{err}")
        return out

    def close(self) -> None:
        self._client.close()

    def __enter__(self):
        return self

    def __exit__(self, *_):
        self.close()


if __name__ == "__main__":
    with SSHClient("${1:192.168.1.100}", user="${2:root}") as ssh:
        print(ssh.run_check("uname -r"))
$0
endsnippet


