# ============================================================================
#  .dockerignore — dotforge Docker build context exclusions
#
#  WHY THIS FILE EXISTS:
#  Docker sends the entire build context (the dotforge directory) to the
#  Docker daemon when you run 'docker build'. Without .dockerignore,
#  it sends everything — including git history, screenshots, and editor
#  temp files — slowing down every build unnecessarily.
#
#  This file tells Docker which files and directories to EXCLUDE from
#  the build context. Smaller context = faster builds.
# ============================================================================

# Git internals — not needed in the container
.git
.gitignore
.gitattributes

# Assets — screenshots and images are for the README, not the container
assets/

# Editor temp files
*.swp
*.swo
*~
.vim/undodir/
.vim/plugged/

# OS-specific
.DS_Store
Thumbs.db

# Local machine-specific config (never goes in the container)
.bash_local

# CI/CD
.github/

# Docs — optional, remove this line if you want docs inside the container
# docs/

# Scripts not needed inside the container
scripts/install.sh
scripts/uninstall.sh
